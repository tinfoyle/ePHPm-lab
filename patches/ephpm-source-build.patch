diff --git a/crates/ephpm/build.rs b/crates/ephpm/build.rs
index eda57d1..909f51e 100644
--- a/crates/ephpm/build.rs
+++ b/crates/ephpm/build.rs
@@ -145,6 +145,13 @@ fn main() {
     }
     println!("cargo::rustc-link-arg=-Wl,--end-group");
     println!("cargo::rustc-link-arg=-Wl,-Bdynamic");
+    // GNU ld resolves libraries left-to-right. ephpm-php emits system libs as
+    // library-crate link directives, which rustc places before this binary
+    // crate's explicit PHP archive group. Re-emit the resolver/libc pair here
+    // after libphp.a so PHP's ext/standard/dns.o references are resolved on
+    // glibc builds, where these symbols may live in libc instead of libresolv.
+    println!("cargo::rustc-link-arg=-lresolv");
+    println!("cargo::rustc-link-arg=-lc");
 
     // Export the binary's own symbols (the Zend/TSRM API baked in from
     // libphp.a) into the dynamic symbol table. Shared PHP extensions loaded
